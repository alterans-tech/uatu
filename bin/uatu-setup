#!/bin/bash
# uatu-setup - One-time user-level MCP and CLI tool installation
# Run once on any machine where you'll use Uatu - The Watcher

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

# Parse flags
FULL_MODE=false
while [[ $# -gt 0 ]]; do
  case $1 in
    --full) FULL_MODE=true; shift ;;
    *) shift ;;
  esac
done

echo ""
echo -e "${CYAN}    ██╗   ██╗ █████╗ ████████╗██╗   ██╗${NC}"
echo -e "${CYAN}    ██║   ██║██╔══██╗╚══██╔══╝██║   ██║${NC}"
echo -e "${CYAN}    ██║   ██║███████║   ██║   ██║   ██║${NC}"
echo -e "${CYAN}    ██║   ██║██╔══██║   ██║   ██║   ██║${NC}"
echo -e "${CYAN}    ╚██████╔╝██║  ██║   ██║   ╚██████╔╝${NC}"
echo -e "${CYAN}     ╚═════╝ ╚═╝  ╚═╝   ╚═╝    ╚═════╝ ${NC}"
echo ""
echo "═══════════════════════════════════════════════════════════════"
echo "  Uatu - The Watcher | User-Level Setup"
if [ "$FULL_MODE" = true ]; then
  echo "  Mode: FULL (includes experimental tools)"
fi
echo "═══════════════════════════════════════════════════════════════"
echo ""

# ─── Prerequisites ─────────────────────────────────────────────────

echo -e "${BLUE}Checking prerequisites...${NC}"
echo ""

MISSING_REQUIRED=()

if ! command -v claude &> /dev/null; then
    echo -e "${RED}✗ claude CLI not found${NC}"
    MISSING_REQUIRED+=("claude (npm install -g @anthropic-ai/claude-code)")
else
    echo -e "${GREEN}✓ claude CLI$(claude --version 2>/dev/null | head -1 || echo '')${NC}"
fi

if ! command -v node &> /dev/null; then
    echo -e "${RED}✗ node not found${NC}"
    MISSING_REQUIRED+=("node 18+ (https://nodejs.org)")
else
    NODE_VERSION=$(node -v | cut -d'v' -f2 | cut -d'.' -f1)
    if [ "$NODE_VERSION" -lt 18 ]; then
        echo -e "${YELLOW}⚠ Node.js v$NODE_VERSION — recommended: 18+${NC}"
    else
        echo -e "${GREEN}✓ Node.js $(node -v)${NC}"
    fi
fi

if ! command -v npx &> /dev/null; then
    echo -e "${RED}✗ npx not found${NC}"
    MISSING_REQUIRED+=("npx (comes with npm)")
else
    echo -e "${GREEN}✓ npx${NC}"
fi

if ! command -v git &> /dev/null; then
    echo -e "${RED}✗ git not found${NC}"
    MISSING_REQUIRED+=("git (https://git-scm.com)")
else
    echo -e "${GREEN}✓ git $(git --version | cut -d' ' -f3)${NC}"
fi

if ! command -v jq &> /dev/null; then
    echo -e "${RED}✗ jq not found (required by all hooks)${NC}"
    MISSING_REQUIRED+=("jq (brew install jq)")
else
    echo -e "${GREEN}✓ jq $(jq --version 2>/dev/null || echo '')${NC}"
fi

if ! command -v gh &> /dev/null; then
    echo -e "${RED}✗ gh (GitHub CLI) not found (required by /pr command)${NC}"
    MISSING_REQUIRED+=("gh (brew install gh)")
else
    echo -e "${GREEN}✓ gh $(gh --version 2>/dev/null | head -1 | cut -d' ' -f3 || echo '')${NC}"
fi

if ! command -v prettier &> /dev/null && ! npx prettier --version &> /dev/null 2>&1; then
    echo -e "${RED}✗ prettier not found (required by format hook)${NC}"
    MISSING_REQUIRED+=("prettier (npm install -g prettier)")
else
    echo -e "${GREEN}✓ prettier${NC}"
fi

echo ""

if [ ${#MISSING_REQUIRED[@]} -gt 0 ]; then
    echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${RED}  Missing required tools:${NC}"
    for tool in "${MISSING_REQUIRED[@]}"; do
        echo -e "${RED}    → $tool${NC}"
    done
    echo -e "${RED}═══════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo "Install the missing tools and run uatu-setup again."
    exit 1
fi

# ─── MCP Servers ───────────────────────────────────────────────────

echo "═══════════════════════════════════════════════════════════════"
echo "  Installing MCP Servers"
echo "═══════════════════════════════════════════════════════════════"
echo ""

install_mcp() {
    local name=$1
    local description=$2
    shift 2
    local cmd="$@"

    echo -e "${BLUE}Installing ${name}...${NC}"
    echo "   ${description}"

    local error_output
    if error_output=$(claude mcp add "$name" -s user -- $cmd 2>&1); then
        echo -e "${GREEN}   ✓ ${name} installed${NC}"
        return 0
    else
        if claude mcp list 2>/dev/null | grep -q "$name"; then
            echo -e "${YELLOW}   ⊘ ${name} already installed (skipping)${NC}"
            return 0
        else
            echo -e "${RED}   ✗ Failed to install ${name}: ${error_output}${NC}"
            return 1
        fi
    fi
    echo ""
}

# Core MCP servers (always installed)
install_mcp "sequential-thinking" \
    "Structured reasoning for /prompt-rewrite, /plan-work, complex tasks" \
    npx -y @modelcontextprotocol/server-sequential-thinking

install_mcp "claude-flow" \
    "SQUAD coordination — shared memory, strategy, agent teams" \
    npx claude-flow@alpha mcp start

install_mcp "context7" \
    "Up-to-date library documentation lookup" \
    npx @upstash/context7-mcp

# Full mode: add experimental tools
if [ "$FULL_MODE" = true ]; then
    echo ""
    echo -e "${BLUE}Installing experimental tools (--full mode)...${NC}"
    install_mcp "ruv-swarm" \
        "Advanced SQUAD/HIVE — DAA agents, neural networks, no timeout" \
        npx ruv-swarm mcp start
fi

echo ""

# ─── CLI Tools ─────────────────────────────────────────────────────

echo "═══════════════════════════════════════════════════════════════"
echo "  Installing CLI Tools"
echo "═══════════════════════════════════════════════════════════════"
echo ""

# Playwright CLI — agent-native browser automation for E2E testing
echo -e "${BLUE}Installing @playwright/cli...${NC}"
echo "   Agent-native browser CLI for E2E testing (--e2e flag)"
if npm install -g @playwright/cli@latest 2>/dev/null; then
    echo -e "${GREEN}   ✓ @playwright/cli installed${NC}"
    echo -e "${BLUE}   Installing Playwright browsers...${NC}"
    if playwright-cli install 2>/dev/null; then
        echo -e "${GREEN}   ✓ Browsers installed${NC}"
    else
        echo -e "${YELLOW}   ⚠ Browser install failed — run 'playwright-cli install' manually${NC}"
    fi
else
    echo -e "${YELLOW}   ⚠ @playwright/cli install failed — run 'npm i -g @playwright/cli@latest' manually${NC}"
fi

echo ""

# ─── Verification ──────────────────────────────────────────────────

echo "═══════════════════════════════════════════════════════════════"
echo "  Verification"
echo "═══════════════════════════════════════════════════════════════"
echo ""

REQUIRED_MCPS=("sequential-thinking" "claude-flow" "context7")
VERIFICATION_FAILED=false

for mcp in "${REQUIRED_MCPS[@]}"; do
    if claude mcp list 2>/dev/null | grep -q "$mcp"; then
        echo -e "  ${GREEN}✓ $mcp${NC}"
    else
        echo -e "  ${RED}✗ $mcp NOT FOUND${NC}"
        VERIFICATION_FAILED=true
    fi
done

if command -v playwright-cli &> /dev/null; then
    echo -e "  ${GREEN}✓ playwright-cli${NC}"
else
    echo -e "  ${YELLOW}⚠ playwright-cli not in PATH${NC}"
fi

echo ""

if [[ "$VERIFICATION_FAILED" == true ]]; then
    echo -e "${RED}Some MCP servers failed to install. Try running uatu-setup again.${NC}"
else
    echo -e "${GREEN}All required tools verified.${NC}"
fi

echo ""
echo "═══════════════════════════════════════════════════════════════"
echo -e "  ${GREEN}Setup Complete!${NC}"
echo "═══════════════════════════════════════════════════════════════"
echo ""
echo "Installed:"
echo "  MCP: sequential-thinking, claude-flow, context7"
if [ "$FULL_MODE" = true ]; then
    echo "  MCP: ruv-swarm (experimental)"
fi
echo "  CLI: @playwright/cli + browsers"
echo ""
echo "Next steps:"
echo "  1. cd /path/to/your-project"
echo "  2. uatu-install"
echo "  3. Edit .env with your tokens"
echo "  4. claude"
echo ""
